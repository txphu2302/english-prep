# Environment Variables for AI English Exam Prep System

# Gemini API Configuration
# For Vite, use VITE_ prefix so the key is available at runtime via import.meta.env
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-flash

# Backwards-compatible names (some setups use REACT_APP_...)
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here
REACT_APP_GEMINI_MODEL=gemini-1.5-flash

# Whisper API Configuration (Local Server)
REACT_APP_WHISPER_API_URL=http://localhost:8000
REACT_APP_WHISPER_API_KEY=optional_whisper_api_key

# Application Settings
REACT_APP_APP_NAME=AI English Exam Prep System
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_WHISPER=true
REACT_APP_ENABLE_GEMINI=true
REACT_APP_ENABLE_SPEECH_SYNTHESIS=true

# Audio Settings
REACT_APP_DEFAULT_SAMPLE_RATE=44100
REACT_APP_DEFAULT_CHANNEL_COUNT=1
REACT_APP_AUDIO_BITS_PER_SECOND=128000

# Session Settings
REACT_APP_MAX_SESSION_DURATION_MINUTES=5
REACT_APP_MAX_QUESTIONS_PER_SESSION=12
REACT_APP_AUTO_SAVE_INTERVAL_SECONDS=30