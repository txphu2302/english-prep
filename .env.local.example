# Next.js Environment Variables
# Copy this to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=https://meowlish.servebeer.com

# Gemini API Configuration
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_MODEL=gemini-1.5-flash

# Whisper API Configuration (Local Server)
NEXT_PUBLIC_WHISPER_API_URL=http://localhost:8000
NEXT_PUBLIC_WHISPER_API_KEY=optional_whisper_api_key

# ElevenLabs API (Server-side only - no NEXT_PUBLIC prefix)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Application Settings
NEXT_PUBLIC_APP_NAME=AI English Exam Prep System
NEXT_PUBLIC_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_WHISPER=true
NEXT_PUBLIC_ENABLE_GEMINI=true
NEXT_PUBLIC_ENABLE_SPEECH_SYNTHESIS=true

# Audio Settings
NEXT_PUBLIC_DEFAULT_SAMPLE_RATE=44100
NEXT_PUBLIC_DEFAULT_CHANNEL_COUNT=1
NEXT_PUBLIC_AUDIO_BITS_PER_SECOND=128000

# Session Settings
NEXT_PUBLIC_MAX_SESSION_DURATION_MINUTES=5
NEXT_PUBLIC_MAX_QUESTIONS_PER_SESSION=12
NEXT_PUBLIC_AUTO_SAVE_INTERVAL_SECONDS=30
